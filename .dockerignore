# Контекст `docker build` — только то, что не нужно для образа Rust-сервера
# (в Dockerfile используются явные COPY; игнор страхует от смены на COPY . .)

# ─── VCS / CI ─────────────────────────────────────────────────────────────
.git/
.github/

# ─── IDE / ассистенты ─────────────────────────────────────────────────────
.idea/
.vscode/
.cursor/
.claude/
.omc/

# ─── Rust (артефакты собираются внутри образа) ────────────────────────────
target/

# ─── Unity / клиент / артефакты под платформы ────────────────────────────
client/
client_decompiled/
client_extracted/
Mines.app/
MinesServer_DO_NOT_READ_ME/

# Патчи/сборки клиента в корне репозитория
Assembly-CSharp*.dll
*.app

# ─── Данные и логи хоста (не вшиваем в слой сборки) ───────────────────────
mines3.db
mines3.db-shm
mines3.db-wal
openmines.db
openmines.db-shm
openmines.db-wal
*.mapb
*.log

# ─── Документация и скрипты деплоя (не участвуют в cargo build) ─────────────
docs/
*.md
scripts/

# ─── Прочее ───────────────────────────────────────────────────────────────
node_modules/
.env
.env.*
**/.DS_Store
