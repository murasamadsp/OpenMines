# ======================================================================
MinesServer_DO_NOT_READ_ME/
MinesSetup.exe

# ======================================================================
# Проект FMOD Studio (если создается в корне репозитория)
# ======================================================================
/FMODProject/.unsaved/
/FMODProject/.user/
/FMODProject/.cache/
/FMODProject/Build/
/FMODProject/Plugins/


# ======================================================================
# FMOD Аудиоинтеграция в Unity (client/Assets)
# ======================================================================
# НЕ игнорируем DLL и библиотеки в FMOD
!/client/[Aa]ssets/Plugins/FMOD/**/lib/*

# НЕ игнорируем изображения и Gizmos FMOD для Unity Editor
!/client/[Aa]ssets/Gizmos/FMOD/*
!/client/[Aa]ssets/Editor Default Resources/FMOD/*

# Игнорируем локальный кэш FMOD
/client/[Aa]ssets/Plugins/FMOD/Cache/*

# Игнорируем скомпилированные банки звуков в StreamingAssets
/client/[Aa]ssets/StreamingAssets/**/*.bank
/client/[Aa]ssets/StreamingAssets/**/*.bank.meta

# Логи редактора FMOD
fmod_editor.log

# ======================================================================
# Состояние ассистентов и AI-настройки
# ======================================================================
.claude/settings.local.json
.omc/

