yarn-error.log*
.pnpm-debug.log*

# ======================================================================
# Клиент Unity (client/)
# ======================================================================
# Исключаем временные папки Unity в подкаталоге client/
/client/[Ll]ibrary/
/client/[Tt]emp/
/client/[Oo]bj/
/client/[Ll]ogs/
/client/[Uu]serSettings/
/client/[Mm]emoryCaptures/
/client/[Bb]uild/
/client/[Bb]uilds/

# Сборки клиента
/client-builds/

# Исключаем метафайлы для проигнорированных папок
/client/[Ll]ibrary.meta
/client/[Tt]emp.meta
/client/[Oo]bj.meta
/client/[Ll]ogs.meta
/client/[Uu]serSettings.meta
/client/[Mm]emoryCaptures.meta
/client/[Bb]uild.meta
/client/[Bb]uilds.meta

# Сгенерированные схемы UI
/client/UIElementsSchema/

# ======================================================================
# Утилиты и инструменты (Tools)
# ======================================================================
# Исключаем bin/obj сборки утилит в tools/
tools/**/bin/
tools/**/obj/

